{
  "app_name": "R&T Express",
  "screen_type": "Login / Sign In",
  "design_system": {
    "background": {
      "outer_gradient": {
        "type": "linear",
        "angle": "to bottom right",
        "colors": ["#E33A25", "#F6A832"],
        "description": "Nền gradient chuyển màu từ đỏ cam sang vàng cam ở góc ngoài cùng"
      },
      "card_container": {
        "background_color": "#FEE6D1",
        "opacity": 0.9,
        "border_radius": "40px",
        "padding": "24px",
        "box_shadow": "0px 10px 30px rgba(0, 0, 0, 0.15)"
      }
    },
    "typography": {
      "font_family": "Sans-serif (e.g., Inter, Roboto, or Montserrat)",
      "styles": {
        "header_title": {
          "text": "R&T Express",
          "font_size": "32px",
          "font_weight": "bold",
          "color": "#C41204",
          "alignment": "center"
        },
        "tab_active": {
          "font_size": "16px",
          "font_weight": "bold",
          "color": "#C41204"
        },
        "tab_inactive": {
          "font_size": "16px",
          "font_weight": "bold",
          "color": "#7E7169"
        },
        "input_placeholder": {
          "font_size": "16px",
          "font_weight": "normal",
          "color": "#A09286"
        },
        "link_text": {
          "text": "Quên mật khẩu?",
          "font_size": "14px",
          "font_weight": "medium",
          "color": "#9E4717",
          "alignment": "right"
        },
        "button_text": {
          "font_size": "18px",
          "font_weight": "bold",
          "color": "#FFFFFF"
        },
        "divider_text": {
          "text": "HOẶC TIẾP TỤC VỚI",
          "font_size": "12px",
          "font_weight": "bold",
          "color": "#A09286"
        }
      }
    },
    "components": {
      "tab_bar": {
        "background_color": "#E9DAD0",
        "border_radius": "25px",
        "padding": "6px",
        "active_tab": {
          "text": "Đăng nhập",
          "background_color": "#FFFFFF",
          "border_radius": "20px"
        },
        "inactive_tab": {
          "text": "Đăng ký",
          "background_color": "transparent"
        }
      },
      "input_fields": {
        "background_color": "#F9F5F2",
        "border_radius": "16px",
        "border": "1px solid #E5D5C9",
        "padding": "14px 16px",
        "box_shadow": "inset 0px 2px 4px rgba(0,0,0,0.05)",
        "icon_color": "#A09286",
        "fields": [
          {
            "id": "username_email",
            "placeholder": "Tên đăng nhập hoặc Email",
            "left_icon": "user-avatar"
          },
          {
            "id": "password",
            "placeholder": "Mật khẩu",
            "left_icon": "lock",
            "right_icon": "eye-off"
          }
        ]
      },
      "primary_button": {
        "text": "Đăng nhập",
        "background_color": "#C41204",
        "border_radius": "20px",
        "padding": "16px",
        "box_shadow": "0px 6px 15px rgba(196, 18, 4, 0.3)",
        "right_icon": "arrow-forward"
      },
      "social_login": {
        "divider": {
          "line_color": "#D7C6BA",
          "thickness": "1px"
        },
        "buttons": {
          "shape": "circle",
          "size": "50px",
          "background_color": "#FFFFFF",
          "box_shadow": "0px 4px 10px rgba(0, 0, 0, 0.1)",
          "platforms": [
            {
              "name": "Facebook",
              "icon_text": "f",
              "color": "#1877F2",
              "font_weight": "bold"
            },
            {
              "name": "Apple",
              "icon_text": "A",
              "color": "#000000",
              "font_weight": "bold"
            },
            {
              "name": "Google",
              "icon_text": "G",
              "color": "#EA4335",
              "font_weight": "bold"
            }
          ]
        }
      }
    },
    "layout_spacing": {
      "margin_top_to_title": "40px",
      "margin_title_to_tabs": "32px",
      "margin_tabs_to_inputs": "24px",
      "gap_between_inputs": "16px",
      "margin_input_to_forgot_password": "12px",
      "margin_forgot_password_to_button": "24px",
      "margin_button_to_divider": "32px",
      "margin_divider_to_social": "20px"
    },
    "ui_error": {
      "username_email": "background trong textfield lỗi hiện hai màu trắng khác nhau",
      "password": "background trong textfield lỗi hiện hai màu trắng khác nhau",
      "login_and_register" : "background trong textfield lỗi hiện hai màu khác nhau"
    }
  }
}